":"Question","name":"Does Nurokind OD Tablet cause drowsiness?","acceptedAnswer":{"@type":"Answer","text":"Yes, Nurokind OD Tablet might cause mild and temporary side effects, including drowsiness, dizziness or sleepiness. "}},{"@type":"Question","name":"Is Nurokind OD Tablet used for B12 deficiency?","acceptedAnswer":{"@type":"Answer","text":"Nurokind-OD Tablet contains vitamin B12 and is mainly used to manage vitamin B12 deficiency and related nerve disorders such as peripheral neuropathy."}}]}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"MedicalWebPage","about":{"@type":"Drug","@id":"https://www.truemeds.in/medicine/nurokind-od-1500-mcg-tablet-20-TM-TACR1-027793#Drug","name":["Nurokind Od Tablet 20"],"image":"https://assets.truemeds.in/Images/ProductImage/TM-TACR1-027793/nurokind-od-tablet-20_nurokind-od-tablet-20--TM-TACR1-027793_1.png","dosageForm":"SUBLINGUAL TABLET","drugUnit":"1.5mg","activeIngredient":"methylcobalamin","description":"Nurokind OD 1500 mcg Tablet is used to treating vitamin B12 deficiency and nerve disorders. Buy Nurokind OD 1500 mcg Tablet online at Truemeds and get free delivery. Know Nurokind OD 1500 mcg Tablet benefits & specifications.","manufacturer":{"@type":"Organization","@id":"https://www.truemeds.in/medicine/nurokind-od-1500-mcg-tablet-20-TM-TACR1-027793#manufacturer","legalName":"Mankind Pharmaceuticals Ltd."},"prescriptionStatus":"https://schema.org/PrescriptionOnly","offers":{"@type":"Offer","url":"https://www.truemeds.in/medicine/nurokind-od-1500-mcg-tablet-20-TM-TACR1-027793","price":169.7,"priceCurrency":"INR","availability":"https://schema.org/InStock","itemCondition":"https://schema.org/NewCondition"}},"mainContentOfPage":"Methylcobalamin (1.5 Mg)","audience":"https://schema.org/Patient","lastReviewed":"2026-07-08","name":"Vitamin Minerals & Supplements, Vitamin B, Vitamin B12","reviewedBy":{"@type":"Person","@id":"https://www.truemeds.in/authors-profile/dr-nikhil-sharma-37","name":"D